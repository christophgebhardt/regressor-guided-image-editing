Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.2.2-cudnn8-devel-ubuntu22.04

%files
    pyproject.toml /opt/project/pyproject.toml
    uv.lock        /opt/project/uv.lock

%post
    apt-get update && apt-get install -y curl git

    # install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    export UV_PYTHON_INSTALL_DIR=/opt/python # default install dir can't be accessed later 

    # set up project with uv
    cd /opt/project && uv sync --frozen

%environment
    export PATH="/opt/project/.venv/bin:$PATH"
    export UV_PYTHON_INSTALL_DIR=/opt/python
    export HF_HOME=/mnt/data/raphael.geiser/huggingface

%runscript
    python "$@"